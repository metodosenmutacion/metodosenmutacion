---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { territoryFamily, FAMILY_NAMES, type TerritoryFamily } from '../lib/territory-colors';

const methods = (await getCollection('methods'))
  .sort((a, b) => b.data.fecha_envio.valueOf() - a.data.fecha_envio.valueOf());

const images = import.meta.glob('/src/content/methods/**/*.{jpg,jpeg,png}', { query: '?url', import: 'default', eager: true });

function getCover(slug: string, doc: string | undefined): string | null {
  if (!doc || !/\.(jpg|jpeg|png)$/i.test(doc)) return null;
  return (images[`/src/content/methods/${slug}/${doc}`] as string) ?? null;
}

const familyOrder: TerritoryFamily[] = ['diseno', 'patronaje', 'materiales', 'costura', 'ajuste', 'exteriores', 'comun'];
---

<Layout title="Métodos en Mutación">
  <div id="vegetal-overlay">
    <div class="vegetal-content">
      <h1>Métodos en Mutación</h1>
      <p class="vegetal-version">v0.1 — en mutación</p>
      <p class="vegetal-hint">Haz clic, desliza o scroll para entrar</p>
    </div>
  </div>

  <section class="home-hero">
    <h1>Métodos en Mutación</h1>
    <p class="measure">Archivo abierto de métodos de creación en moda. Cualquiera puede leerlo, descargarlo, contribuir.</p>
  </section>

  <section class="home-cartography">
    <div class="filter-chips" role="toolbar" aria-label="Filtros de territorio">
      <button class="filter-chip active" data-family="all">Todos</button>
      {familyOrder.map(family => (
        <button class="filter-chip" data-family={family} style={`--chip-color: var(--color-${family});`}>
          {FAMILY_NAMES[family]}
        </button>
      ))}
    </div>

    {methods.length === 0 ? (
      <p>Aún no hay métodos en el archivo.</p>
    ) : (
      <div class="cartography">
        {methods.map((method, i) => {
          const slug = method.id.split('/')[0];
          const cover = getCover(slug, method.data.documentacion[0]);
          const primaryTerritory = method.data.territorios[0];
          const family = territoryFamily(primaryTerritory);
          const isFundacional = method.data.territorios.includes('COMÚN');
          const rotation = ((i % 5) - 2) * 0.8;
          return (
            <a
              href={`/metodos/${slug}/`}
              class={`method-card territory-${family} ${isFundacional ? 'fundacional' : ''}`}
              style={`transform: rotate(${rotation}deg);`}
            >
              {cover && <img src={cover} alt={method.data.titulo} class="card-cover" />}
              <div class="card-body">
                <h2 class="card-title">{method.data.titulo}</h2>
                <p class="card-meta">{method.data.autoria.join(', ')}</p>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>

  <script is:inline>
    // Overlay papel vegetal: respuesta a scroll, wheel, click y touch
    (function () {
      const overlay = document.getElementById('vegetal-overlay');
      if (!overlay) return;

      let progress = 0;
      let dismissed = false;

      function setProgress(p) {
        if (dismissed) return;
        progress = Math.max(0, Math.min(1, p));
        overlay.style.opacity = String(1 - progress);
        if (progress >= 0.95) {
          dismissed = true;
          overlay.style.pointerEvents = 'none';
        }
      }

      function dismiss() {
        dismissed = true;
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
      }

      // Scroll de página (cuando hay contenido suficiente para scrollear)
      window.addEventListener('scroll', function () {
        if (dismissed) return;
        setProgress(window.scrollY / 400);
      }, { passive: true });

      // Rueda del ratón (funciona aunque la página no pueda scrollear)
      overlay.addEventListener('wheel', function (e) {
        e.preventDefault();
        if (e.deltaY > 0) {
          setProgress(progress + 0.08);
        }
      }, { passive: false });

      // Gesto táctil (móvil)
      let touchStartY = 0;
      overlay.addEventListener('touchstart', function (e) {
        touchStartY = e.touches[0].clientY;
      }, { passive: true });
      overlay.addEventListener('touchmove', function (e) {
        const diff = touchStartY - e.touches[0].clientY;
        if (diff > 0) {
          setProgress(progress + diff * 0.004);
        }
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      // Clic en cualquier punto del overlay: dismiss instantáneo
      overlay.addEventListener('click', dismiss);
    })();

    // Filtros por familia de territorio
    (function () {
      const chips = document.querySelectorAll('.filter-chip');
      const cartography = document.querySelector('.cartography');
      if (!cartography) return;
      const families = ['diseno', 'patronaje', 'materiales', 'costura', 'ajuste', 'exteriores', 'comun'];
      chips.forEach(function (chip) {
        chip.addEventListener('click', function (e) {
          e.preventDefault();
          chips.forEach(function (c) { c.classList.remove('active'); });
          chip.classList.add('active');
          const family = chip.getAttribute('data-family');
          families.forEach(function (f) { cartography.classList.remove('only-' + f); });
          if (family !== 'all') {
            cartography.classList.add('only-' + family);
          }
        });
      });
    })();
  </script>
</Layout>
