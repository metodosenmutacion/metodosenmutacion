---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { territoryFamily, FAMILY_NAMES, type TerritoryFamily } from '../lib/territory-colors';

const methods = (await getCollection('methods'))
  .sort((a, b) => b.data.fecha_envio.valueOf() - a.data.fecha_envio.valueOf());

const images = import.meta.glob('/src/content/methods/**/*.{jpg,JPG,jpeg,JPEG,png,PNG,webp,WEBP}', { query: '?url', import: 'default', eager: true });

function getCover(slug: string, docs: string[] | undefined): string | null {
  if (!docs || docs.length === 0) return null;
  const firstImage = docs.find(d => /\.(jpg|jpeg|png|webp)$/i.test(d));
  if (!firstImage) return null;
  return (images[`/src/content/methods/${slug}/${firstImage}`] as string) ?? null;
}

function mulberry32(a: number) {
  return function () {
    a |= 0;
    a = a + 0x6D2B79F5 | 0;
    let t = Math.imul(a ^ a >>> 15, 1 | a);
    t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
    return ((t ^ t >>> 14) >>> 0) / 4294967296;
  };
}

const positions = methods.map((m, i) => {
  if (m.data.territorios.includes('COMÚN')) {
    return { top: 40, left: 42, rotation: -2 };
  }
  const rng = mulberry32((i + 1) * 12347);
  return {
    top: 4 + rng() * 82,
    left: 3 + rng() * 88,
    rotation: (rng() - 0.5) * 8,
  };
});

const slugIndex: Record<string, number> = {};
methods.forEach((m, i) => { slugIndex[m.id.split('/')[0]] = i; });

interface Edge { from: string; to: string; family: string; }
const edges: Edge[] = [];
methods.forEach(method => {
  const slug = method.id.split('/')[0];
  const family = territoryFamily(method.data.territorios[0]);
  method.data.derivado_de.forEach(d => {
    if (d.tipo === 'interno' && slugIndex[d.slug] !== undefined) {
      edges.push({ from: slug, to: d.slug, family });
    }
  });
});

const familyOrder: TerritoryFamily[] = ['diseno', 'patronaje', 'materiales', 'costura', 'ajuste', 'exteriores', 'comun'];
---

<Layout title="Métodos en Mutación">
  <div id="vegetal-overlay">
    <div class="vegetal-content">
      <h1>Métodos en Mutación</h1>
      <p class="vegetal-version">v0.1 — en mutación</p>
      <p class="vegetal-hint">Haz clic, desliza o scroll para entrar</p>
    </div>
  </div>

  <section class="home-hero">
    <h1>Métodos en Mutación</h1>
    <p class="measure">Archivo abierto de métodos de creación en moda. Cualquiera puede leerlo, descargarlo, contribuir.</p>
  </section>

  <section class="home-cartography">
    <div class="filter-chips" role="toolbar" aria-label="Filtros de territorio">
      <button class="filter-chip active" data-family="all">Todos</button>
      {familyOrder.map(family => (
        <button class="filter-chip" data-family={family} style={`--chip-color: var(--color-${family});`}>
          {FAMILY_NAMES[family]}
        </button>
      ))}
    </div>

    {methods.length === 0 ? (
      <p>Aún no hay métodos en el archivo.</p>
    ) : (
      <div class="cartography">
        <svg class="cartography-lines" xmlns="http://www.w3.org/2000/svg">
          {edges.map(edge => {
            const fromPos = positions[slugIndex[edge.from]];
            const toPos = positions[slugIndex[edge.to]];
            if (!fromPos || !toPos) return null;
            return (
              <line
                class={`derivation-line family-${edge.family}`}
                x1={`${fromPos.left}%`}
                y1={`${fromPos.top}%`}
                x2={`${toPos.left}%`}
                y2={`${toPos.top}%`}
              />
            );
          })}
        </svg>

        {methods.map((method, i) => {
          const slug = method.id.split('/')[0];
          const cover = getCover(slug, method.data.documentacion);
          const primaryTerritory = method.data.territorios[0];
          const family = territoryFamily(primaryTerritory);
          const isFundacional = method.data.territorios.includes('COMÚN');
          const pos = positions[i];
          return (
            <a
              href={`/metodos/${slug}/`}
              class={`map-node territory-${family} ${isFundacional ? 'fundacional' : ''}`}
              style={`left: ${pos.left}%; top: ${pos.top}%; transform: rotate(${pos.rotation}deg);`}
              data-family={family}
            >
              {cover && <img src={cover} alt={method.data.titulo} class="node-image" />}
              <div class="node-caption">
                <span class="node-title">{method.data.titulo}</span>
                <span class="node-meta">{method.data.autoria.join(', ')}</span>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </section>

  <script is:inline>
    // Overlay papel vegetal
    (function () {
      const overlay = document.getElementById('vegetal-overlay');
      if (!overlay) return;

      let progress = 0;
      let dismissed = false;

      function setProgress(p) {
        if (dismissed) return;
        progress = Math.max(0, Math.min(1, p));
        overlay.style.opacity = String(1 - progress);
        if (progress >= 0.95) {
          dismissed = true;
          overlay.style.pointerEvents = 'none';
        }
      }

      function dismiss() {
        dismissed = true;
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
      }

      window.addEventListener('scroll', function () {
        if (dismissed) return;
        setProgress(window.scrollY / 400);
      }, { passive: true });

      overlay.addEventListener('wheel', function (e) {
        e.preventDefault();
        if (e.deltaY > 0) {
          setProgress(progress + 0.08);
        }
      }, { passive: false });

      let touchStartY = 0;
      overlay.addEventListener('touchstart', function (e) {
        touchStartY = e.touches[0].clientY;
      }, { passive: true });
      overlay.addEventListener('touchmove', function (e) {
        const diff = touchStartY - e.touches[0].clientY;
        if (diff > 0) {
          setProgress(progress + diff * 0.004);
        }
        touchStartY = e.touches[0].clientY;
      }, { passive: true });

      overlay.addEventListener('click', dismiss);
    })();

    // Filtros por familia
    (function () {
      const chips = document.querySelectorAll('.filter-chip');
      const cartography = document.querySelector('.cartography');
      if (!cartography) return;
      const families = ['diseno', 'patronaje', 'materiales', 'costura', 'ajuste', 'exteriores', 'comun'];
      chips.forEach(function (chip) {
        chip.addEventListener('click', function (e) {
          e.preventDefault();
          chips.forEach(function (c) { c.classList.remove('active'); });
          chip.classList.add('active');
          const family = chip.getAttribute('data-family');
          families.forEach(function (f) { cartography.classList.remove('only-' + f); });
          if (family !== 'all') {
            cartography.classList.add('only-' + family);
          }
        });
      });
    })();
  </script>
</Layout>
