---
import { getCollection } from 'astro:content';
import { TERRITORIOS } from '../../content.config';
import { territoryFamily } from '../../lib/territory-colors';
import { slugify } from '../../lib/slugify';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  return TERRITORIOS.map(t => ({
    params: { slug: slugify(t) },
    props: { name: t },
  }));
}

const { name } = Astro.props;
const family = territoryFamily(name);

const methods = (await getCollection('methods'))
  .filter(m => m.data.territorios.includes(name))
  .sort((a, b) => b.data.fecha_envio.valueOf() - a.data.fecha_envio.valueOf());

const images = import.meta.glob('/src/content/methods/**/*.{jpg,JPG,jpeg,JPEG,png,PNG,webp,WEBP}', { query: '?url', import: 'default', eager: true });

function getCover(slug: string, doc: string | undefined): string | null {
  if (!doc || !/\.(jpg|jpeg|png|webp)$/i.test(doc)) return null;
  return (images[`/src/content/methods/${slug}/${doc}`] as string) ?? null;
}
---

<Layout title={`Territorio ${name} · Métodos en Mutación`}>
  <h1 class={`territory-heading territory-${family}`}>{name}</h1>
  <p class="measure">{methods.length} {methods.length === 1 ? 'método declara' : 'métodos declaran'} este territorio.</p>

  {methods.length === 0 ? (
    <p>Aún ningún método declara este territorio.</p>
  ) : (
    <div class="method-grid">
      {methods.map(method => {
        const slug = method.id.split('/')[0];
        const cover = getCover(slug, method.data.documentacion[0]);
        const primaryTerritory = method.data.territorios[0];
        const cardFamily = territoryFamily(primaryTerritory);
        return (
          <a href={`/metodos/${slug}/`} class={`method-card territory-${cardFamily}`}>
            {cover && <img src={cover} alt={method.data.titulo} class="card-cover" />}
            <div class="card-body">
              <h2 class="card-title">{method.data.titulo}</h2>
              <p class="card-meta">{method.data.autoria.join(', ')}</p>
            </div>
          </a>
        );
      })}
    </div>
  )}
</Layout>
