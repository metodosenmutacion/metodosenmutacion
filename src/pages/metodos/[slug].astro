---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { territoryFamily } from '../../lib/territory-colors';
import { slugify } from '../../lib/slugify';

export async function getStaticPaths() {
  const methods = await getCollection('methods');
  return methods.map(method => ({
    params: { slug: method.id.split('/')[0] },
    props: { method },
  }));
}

const { method } = Astro.props;
const { Content } = await render(method);

const allDocs = import.meta.glob('/src/content/methods/**/*.{jpg,jpeg,png,pdf}', { query: '?url', import: 'default', eager: true });

const methodSlug = method.id.split('/')[0];

function resolveDoc(filename: string): string {
  const key = `/src/content/methods/${methodSlug}/${filename}`;
  return allDocs[key] as string;
}

function isImage(filename: string): boolean {
  return /\.(jpg|jpeg|png)$/i.test(filename);
}

const fechaFormat = method.data.fecha_envio.toLocaleDateString('es-ES', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<Layout title={`${method.data.titulo} · Métodos en Mutación`}>
  <article class="method-ficha">
    <header class="ficha-header">
      <h1>{method.data.titulo}</h1>
    </header>

    <div class="ficha-grid">
      <div class="ficha-docs">
        {method.data.documentacion.map(doc => (
          <div class="doc-item">
            {isImage(doc) ? (
              <>
                <img src={resolveDoc(doc)} alt={doc} />
                <a href={resolveDoc(doc)} download class="doc-download">Descargar</a>
              </>
            ) : (
              <a href={resolveDoc(doc)} target="_blank" rel="noopener" class="doc-pdf">📄 {doc}</a>
            )}
          </div>
        ))}
      </div>

      <aside class="ficha-meta">
        <div class="meta-row">
          <span class="meta-label">Autoría</span>
          <div class="meta-value">
            {method.data.autoria.map(a => <div>{a}</div>)}
          </div>
        </div>

        <div class="meta-row">
          <span class="meta-label">Territorios</span>
          <div class="meta-value territories">
            {method.data.territorios.map(t => {
              const family = territoryFamily(t);
              return (
                <a href={`/territorios/${slugify(t)}/`} class={`territory-chip territory-${family}`}>
                  {t}
                </a>
              );
            })}
          </div>
        </div>

        <div class="meta-row">
          <span class="meta-label">Derivado de</span>
          <div class="meta-value">
            {method.data.derivado_de.length === 0 ? (
              <em>Original — sin derivaciones</em>
            ) : (
              method.data.derivado_de.map(d =>
                d.tipo === 'interno' ? (
                  <div><a href={`/metodos/${d.slug}/`}>{d.slug}</a></div>
                ) : (
                  <div><a href={`/referentes/${slugify(d.nombre)}/`}>{d.nombre}</a></div>
                )
              )
            )}
          </div>
        </div>

        <div class="meta-row">
          <span class="meta-label">Fecha de envío</span>
          <span class="meta-value">{fechaFormat}</span>
        </div>

        <div class="meta-row">
          <span class="meta-label">Licencia</span>
          <span class="meta-value">
            <a href="/licencia/" class="license-link">{method.data.licencia}</a>
          </span>
        </div>
      </aside>
    </div>

    <section class="ficha-body measure">
      <Content />
    </section>
  </article>
</Layout>
